{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Setup venv & install",
      "type": "shell",
      "command": "python3 -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "build"
    },
    {
      "label": "Frontend: Install",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "build"
    },
    {
      "label": "Backend: Run server",
      "type": "shell",
      "command": "source .venv/bin/activate && uvicorn app.main:app --reload",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Frontend: Dev server",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Backend: Test",
      "type": "shell",
      "command": "source .venv/bin/activate && pytest -v",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "test"
    },
    {
      "label": "Backend: Lint (Ruff)",
      "type": "shell",
      "command": "source .venv/bin/activate && ruff check . && ruff format --check .",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "test"
    },
    {
      "label": "Frontend: Lint",
      "type": "shell",
      "command": "npm run lint",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "test"
    },
    {
      "label": "Full Setup",
      "dependsOn": ["Backend: Setup venv & install", "Frontend: Install"],
      "group": "build"
    }
  ]
}
